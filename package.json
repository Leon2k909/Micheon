{
  "name": "germ",
  "private": true,
  "version": "1.0.5",
  "description": "Micheon — offline lessons with premium voice, spaced repetition, and gaming vocabulary.",
  "author": "Leon",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,tts -c cyan,magenta \"vite\" \"node server/index.js\"",
    "dev:web": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "electron": "npm run build && electron .",
    "electron:run": "electron .",
    "electron:dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.germ.germanlab",
    "productName": "Micheon",
    "files": [
      "electron/**",
      "server/**",
      "dist/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Leon2k909",
      "repo": "Micheon",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react-grid-layout": "^1.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "edge-tts-universal": "^1.4.0",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "framer-motion": "^12.36.0",
    "level": "^10.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^1.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "vite": "^6.3.5"
  }
}
